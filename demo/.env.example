# Copy to .env and fill in your values
# Used by demo/app.py at startup

# LLM endpoint (OpenAI-compatible)
API_URL=http://localhost:11434/v1       # Ollama local
# API_URL=https://api.openai.com/v1    # OpenAI
# API_URL=https://api-inference.huggingface.co/v1  # HF Inference

# API key (use "ollama" for local Ollama, no auth needed)
API_KEY=ollama
# API_KEY=sk-...                        # OpenAI key
# API_KEY=hf_...                        # HF token

# Model name — must support tool/function calling
DEFAULT_MODEL=llama3.2:3b
# DEFAULT_MODEL=gpt-4o-mini
# DEFAULT_MODEL=Qwen/Qwen2.5-72B-Instruct

# Sandbox database path (SQLite)
MAYFLOWER_DB_PATH=/tmp/mayflower_demo.db

# Gradio server
GRADIO_SERVER_PORT=7860
